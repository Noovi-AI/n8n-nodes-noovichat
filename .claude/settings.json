{
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "50000",
    "MAX_MCP_OUTPUT_TOKENS": "25000"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm publish:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(du -sh:*)",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(gh:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(npm version:*)",
      "Bash(npm pack:*)",
      "Bash(npm view:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push -f:*)",
      "Bash(git clean -fd:*)"
    ]
  }
}